---
import TEXTURE_SRC from '@/assets/coin/texture';

interface Props {
  movedIn?: number;
  stopIn?: number;
}

const { movedIn, stopIn } = Astro.props;
---

<div
  id="coin-container"
  class="flex items-center justify-center inset-0 -z-10 pointer-events-none h-[50vh]"
>
</div>

<script is:inline define:vars={{ TEXTURE_SRC, movedIn, stopIn }}>
  (function() {
    // Load dependencies from CDN
    const scripts = [
      { id: 'three-js', src: 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js' },
      { id: 'gsap-js', src: 'https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js' }
    ];

    let loadedCount = 0;
    scripts.forEach(s => {
      if (!window[s.id === 'three-js' ? 'THREE' : 'gsap']) {
        const script = document.createElement('script');
        script.src = s.src;
        script.onload = () => {
          loadedCount++;
          if (loadedCount === scripts.filter(sc => !window[sc.id === 'three-js' ? 'THREE' : 'gsap']).length || loadedCount === scripts.length) init();
        };
        document.head.appendChild(script);
      } else {
        loadedCount++;
        if (loadedCount === scripts.length) init();
      }
    });

    function init() {
      if (!window.THREE || !window.gsap) return;
      const THREE = window.THREE;
      const gsap = window.gsap;
      const container = document.getElementById('coin-container');
      if (!container) return;

    // --- Interaction Props ---
    const rotationFactor = 0.015;

    // --- Renderer ---
    const renderer = new THREE.WebGLRenderer({
      antialias: true,
      alpha: true,
    });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;
    renderer.domElement.style.width = '100%';
    renderer.domElement.style.height = '100%';
    renderer.domElement.style.display = 'block';
    container.appendChild(renderer.domElement);

    // --- Scene + Camera ---
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      50,
      container.clientWidth / container.clientHeight,
      0.1,
      1000
    );
    camera.position.z = 4;

    // --- Texture + Materials ---
    const loader = new THREE.TextureLoader();
    const texture = loader.load(TEXTURE_SRC);
    const faceMat = new THREE.MeshStandardMaterial({
      map: texture,
      roughness: 0.25,
      metalness: 0.7,
      side: THREE.DoubleSide,
    });

    const edgeMat = new THREE.MeshStandardMaterial({
      color: 0xa87064, // terracotta rose gold rim
      roughness: 0.3,
      metalness: 0.6,
    });

    const backTexture = loader.load(TEXTURE_SRC);
    backTexture.rotation = Math.PI;
    backTexture.center.set(0.5, 0.5);
    const backMat = new THREE.MeshStandardMaterial({
      map: backTexture,
      roughness: 0.18,
      metalness: 0.6,
      envMapIntensity: 1.2,
    });

    // --- Coin Mesh ---
    const coin = new THREE.Mesh(
      new THREE.CylinderGeometry(1.5, 1.5, 0.06, 128),
      [edgeMat, faceMat, backMat]
    );
    coin.rotation.x = Math.PI / 2;

    const pivot = new THREE.Group();
    pivot.add(coin);
    pivot.rotation.z = Math.PI / 2;
    scene.add(pivot);

    // --- Lighting ---
    const keyLight = new THREE.DirectionalLight(0xfff0d0, 4);
    keyLight.position.set(3, 5, 4);
    const fillLight = new THREE.DirectionalLight(0xaabbff, 1.2);
    fillLight.position.set(-4, -2, 2);
    const rimLight = new THREE.DirectionalLight(0xffe0a0, 2);
    rimLight.position.set(0, -4, -3);
    const shimmer = new THREE.PointLight(0xffd080, 2, 8);
    shimmer.position.set(1, 1, 3);
    scene.add(keyLight, fillLight, rimLight, shimmer);
    scene.add(new THREE.AmbientLight(0xffffff, 0.3));

    // --- Interaction with GSAP ---
    let isDragging = false;
    let startX = 0;
    let rotationAtStart = 0;
    let rotationTarget = 0;
    
    const rotationProxy = { y: 0 };
    const WORLD_Y = new THREE.Vector3(0, 1, 0);
    let lastRotationCount = 0;

    function updateRotation() {
      // Use Euler rotation to preserve the initial pivot.rotation.z
      pivot.rotation.y = rotationProxy.y;

      // Detect 360 degree flips (2*PI radians)
      const currentRotationCount = Math.floor(Math.abs(rotationProxy.y) / (Math.PI * 1));
      if (currentRotationCount > lastRotationCount) {
        console.log("360 degree flip completed!");
        lastRotationCount = currentRotationCount;
      } else if (currentRotationCount < lastRotationCount) {
        // Reset count if rotating backwards past a threshold
        lastRotationCount = currentRotationCount;
      }
    }

    function onStart(x) {
      isDragging = true;
      startX = x;
      rotationAtStart = rotationTarget;
      gsap.killTweensOf(rotationProxy);
    }

    function onMove(x) {
      if (!isDragging) return;
      
      const dx = x - startX;
      // Map drag distance to rotation (e.g., drag width of screen = 360 degrees)
      const dragRotation = (dx / window.innerWidth) * Math.PI * 2;
      rotationTarget = rotationAtStart + dragRotation;
      
      gsap.to(rotationProxy, {
        y: rotationTarget,
        duration: 0.6,
        ease: "power2.out",
        onUpdate: updateRotation
      });
    }

    function onEnd() {
      if (!isDragging) return;
      isDragging = false;
      
      // Rotate the coin back to face the front (0 radians)
      gsap.to(rotationProxy, {
        y: 0,
        duration: 1.5,
        ease: "power3.out",
        onUpdate: updateRotation,
        onComplete: () => {
          rotationTarget = 0;
          lastRotationCount = 0;
        }
      });
    }

    // Attach listeners to the parent section instead of just the canvas
    const section = container.closest('section');
    const interactionTarget = section || container;
    
    // Ensure the section can receive pointer events
    if (section) section.style.pointerEvents = 'auto';
    
    interactionTarget.addEventListener("mousedown", e => onStart(e.clientX));
    window.addEventListener("mousemove", e => onMove(e.clientX));
    window.addEventListener("mouseup", onEnd);
    
    interactionTarget.addEventListener("touchstart", e => { 
      onStart(e.touches[0].clientX);
    }, { passive: true });
    window.addEventListener("touchmove",  e => { 
      onMove(e.touches[0].clientX);
    }, { passive: true });
    window.addEventListener("touchend", onEnd);

    // --- Animation loop ---
    let clock = 0;
    function animate() {
      requestAnimationFrame(animate);
      clock += 0.01;
      
      shimmer.position.set(
        Math.sin(clock * 0.7) * 2,
        Math.cos(clock * 0.5) * 2,
        3
      );

      renderer.render(scene, camera);
    }
    animate();

    // --- Resize observer ---
    const ro = new ResizeObserver(() => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      renderer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    });
    ro.observe(container);
    }
  })();
</script>

<style>
  #coin-container {
    background: transparent;
    cursor: grab;
    overflow: hidden;
  }
</style>
