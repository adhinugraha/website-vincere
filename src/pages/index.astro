---
// Import the necessary component
import CoinMobileBackground from '@/components/CoinMobileBackground.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import Navbar from '@components/sections/navbar&footer/Navbar.astro';
import NavbarMobile from '@components/sections/navbar&footer/NavbarMobile.astro';
import NavSection from '@components/sections/navbar&footer/NavSection.astro';
import CoinBackground from '@components/CoinBackground.astro';
import { Image } from "astro:assets";
import pinIcon from "@/images/pin-icon.png";
import emailIcon from "@/images/email-icon.png";
---
<MainLayout>
    <div class="relative z-10 main-container home-container">
        <section class="flex flex-col hero-coin section-hero" id="section-hero">
            <h1 class="text-[2em] md:text-6xl text-white font-primary text-center leading-[1.25] mb-[20px]">
                Building a Stronger Local Network for Workers & Businesses in Bali
            </h1>
            <h2 class="text-white font-secondary text-center leading-[1.5]">
                We are organizing drivers, workers and merchants intor a structured community network that will provide better coordination, visibility and future financial access.
            </h2>
            <CoinMobileBackground />
        </section>
        <NavSection />
        <div class="slick-slider" data-slick='{"slidesToShow": 1, "slidesToScroll": 1, "vertical": false, "verticalSwiping": false, "dots": false, "arrows": false, "infinite": false}'>
            <section class="flex items-center justify-center flex-col" id="contact">
                <h3 class="text-4xl text-white px-3 color-rosegold text-center mb-[10px]">Institutional Enquiries</h3>
                <p class="text-white font-secondary text-center leading-[1.5] mb-[20px]">
                    All Engagements are conducted by appointments only
                </p>
                <div class="w-full h-[100vw] overflow-hidden mb-[30px]">
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d466.8284402163347!2d103.84762266179024!3d1.2783941024534091!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31da190da29d46cf%3A0xdafb9cf3d50811f2!2sSleek!5e0!3m2!1sen!2sid!4v1772726038179!5m2!1sen!2sid"
                        width="100%"
                        height="100%"
                        style={{
                        border: 0,
                        display: "block",
                        filter: "invert(90%) hue-rotate(180deg) saturate(0.85) brightness(0.95)",
                        }}
                        allowfullscreen={true}
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        title="Vincere One Reserve Location"
                    />
                </div>

                <div class="flex items-center gap-6 py-[10px]">
                    <Image 
                        src={pinIcon} 
                        alt="Vincere Logo" 
                        class="h-[40px] w-auto object-contain"
                        loading="eager"
                    />
                    <p class="text-white">160 Robinson Road, #14-04 SBF Center, Singapore 068914</p>
                </div>
                <div class="flex items-center gap-6 py-[10px]">
                    <Image 
                        src={emailIcon} 
                        alt="Vincere Logo" 
                        class="h-[40px] w-auto object-contain"
                        loading="eager"
                    />
                    <p class="text-white">sya@vincereonereserve.com</p>
                </div>
            </section>
        </div>
    </div>
</MainLayout>

<script is:inline src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

<script is:inline>
  $(document).ready(function(){
    const $slider = $('.slick-slider');
    
    $slider.slick({
      vertical: true,
      verticalSwiping: true,
      slidesToShow: 1,
      slidesToScroll: 1,
      dots: true,
      arrows: false,
      infinite: false,
      speed: 1000,
      cssEase: 'cubic-bezier(0.645, 0.045, 0.355, 1)'
    });

    // Handle mousewheel for vertical scrolling
    $slider.on('wheel', function(e) {
      const slick = $slider.slick('getSlick');
      const currentSlide = slick.currentSlide;
      const totalSlides = slick.slideCount;
      const deltaY = e.originalEvent.deltaY;

      // Allow scrolling up from the first slide to the hero
      if (currentSlide === 0 && deltaY < 0) {
        return; // Let native scroll handle it
      }

      // Allow scrolling down from the last slide
      if (currentSlide === totalSlides - 1 && deltaY > 0) {
        return; // Let native scroll handle it
      }

      e.preventDefault();
      if (deltaY > 0) {
        $(this).slick('slickNext');
      } else {
        $(this).slick('slickPrev');
      }
    });

    // Sync CoinBackground progress with Slick Slider
    $slider.on('afterChange', function(event, slick, currentSlide) {
      const totalSlides = slick.slideCount;
      const progress = currentSlide / (totalSlides - 1);
      
      // Get the ID of the current slide's section
      const $currentSlide = $(slick.$slides.get(currentSlide));
      const sectionId = $currentSlide.find('section[id]').attr('id') || $currentSlide.attr('id');
      
      // Calculate VH for scroll spy and other listeners
      const vh = progress * (document.documentElement.scrollHeight / window.innerHeight) * 100;
      window.dispatchEvent(new CustomEvent('coin-scroll', { detail: { vh, progress, sectionId, currentSlide } }));
    });

    // Handle manual scroll to sync mobile nav when reaching the hero
    $(window).on('scroll', function() {
      if ($(window).scrollTop() < 50) {
        window.dispatchEvent(new CustomEvent('coin-scroll', { detail: { vh: 0, progress: 0, sectionId: 'section-hero', currentSlide: -1 } }));
      }
    });

    // Handle nav clicks for Slick
    $('nav a[href^="#"]').on('click', function(e) {
      const targetId = $(this).attr('href');
      if (targetId === '#') return;
      
      const $target = $(targetId);
      if ($target.length) {
        // Find the index of the slide containing the target element
        const slideIndex = $target.closest('.slick-slide').data('slick-index');
        if (typeof slideIndex !== 'undefined') {
          e.preventDefault();
          e.stopImmediatePropagation(); // Prevent other listeners like Lenis
          $slider.slick('slickGoTo', slideIndex);
        } else if (targetId === '#section-hero') {
          // If we're scrolling to the hero, let Lenis handle it or scroll naturally
          // We don't preventDefault here
        }
      }
    });
  });
</script>

<style is:global>
  /* Ensure the slider and its slides take full height */
  .slick-slider, .slick-list, .slick-track {
    height: 100vh !important;
  }
  
  .slick-slide {
    height: 100vh !important;
  }

  /* Custom Slick Dots Styling */
  .slick-dots {
    position: fixed;
    right: 30px;
    top: 50%;
    transform: translateY(-50%);
    display: flex !important;
    flex-direction: column;
    width: auto;
    bottom: auto;
    z-index: 100;
  }
  
  .slick-dots li {
    margin: 10px 0;
  }
  
  .slick-dots li button:before {
    color: white !important;
    font-size: 12px;
    opacity: 0.5;
  }
  
  .slick-dots li.slick-active button:before {
    opacity: 1;
    color: #ff801f !important; /* Orange accent */
  }
</style>
